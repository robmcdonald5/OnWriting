# Google Gemini API Key (required for LLM calls)
GOOGLE_API_KEY=your-google-api-key-here

# LangSmith tracing (optional - works without it during early dev)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ai-writer-prototype

# Vertex AI Fine-Tuning (optional — all default to mock mode)
# VERTEX_API_KEY=your-vertex-api-key-here
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_REGION=us-central1
# VERTEX_BUCKET_NAME=your-gcs-bucket-name
# VERTEX_TUNED_MODEL_ENDPOINT=projects/123/locations/us-central1/endpoints/456
# FINE_TUNING_MOCK_MODE=true

# Openrouter API Key
OPENROUTER_API_KEY=your-openrouter-api-key-here